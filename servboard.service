[Unit]
Description=Servboard - Remote Server Dashboard
After=network.target

[Service]
Type=simple
User=ed
WorkingDirectory=/home/ed/Davit/Projects/Servboard
ExecStart=/usr/bin/python3 main.py
Restart=always
Environment=FLET_SERVER_PORT=3000
Environment=WEB_MODE=1
Environment=SCRIPTS_ROOT=/home/user/main



[Install]
WantedBy=multi-user.target
